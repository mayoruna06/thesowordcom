{
  "permissions": {
    "allow": [
      "Bash(gh --version)",
      "Bash(aws --version)",
      "Bash(pnpm --version)",
      "Bash(command -v gh)",
      "Bash(command -v aws)",
      "Bash(command -v pnpm)",
