---
import type { CollectionEntry } from 'astro:content';

interface Props {
  workSlug: string;
  prev?: CollectionEntry<'chapters'>;
  next?: CollectionEntry<'chapters'>;
}

const { workSlug, prev, next } = Astro.props;
---

<nav class="chapter-nav" aria-label="章節導覽">
  <div class="chapter-nav__inner">
    <div class="chapter-nav__prev">
      {prev && (
        <a href={`/works/${workSlug}/${prev.slug}/`} class="chapter-nav__btn chapter-nav__btn--prev">
          <span class="chapter-nav__arrow">←</span>
          <span class="chapter-nav__label">
            <span class="chapter-nav__hint">上一章</span>
            <span class="chapter-nav__title">{prev.data.title}</span>
          </span>
        </a>
      )}
    </div>

    <a href={`/works/${workSlug}/`} class="chapter-nav__index" title="回到作品目錄">目錄</a>

    <div class="chapter-nav__next">
      {next && (
        <a href={`/works/${workSlug}/${next.slug}/`} class="chapter-nav__btn chapter-nav__btn--next">
          <span class="chapter-nav__label">
            <span class="chapter-nav__hint">下一章</span>
            <span class="chapter-nav__title">{next.data.title}</span>
          </span>
          <span class="chapter-nav__arrow">→</span>
        </a>
      )}
    </div>
  </div>
</nav>

<style>
  .chapter-nav {
    border-top: 1px solid var(--color-border);
    padding: var(--space-6) 0;
    margin-top: var(--space-8);
  }

  .chapter-nav__inner {
    max-width: var(--max-width-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-4);
    align-items: center;
    padding: 0 var(--space-4);
  }

  .chapter-nav__btn {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition), border-color var(--transition);
    min-width: 0;
  }

  .chapter-nav__btn:hover {
    background: var(--color-surface);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .chapter-nav__btn--next { justify-content: flex-end; }

  .chapter-nav__label {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .chapter-nav__btn--next .chapter-nav__label { align-items: flex-end; }

  .chapter-nav__hint {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .chapter-nav__title {
    font-size: var(--text-sm);
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  .chapter-nav__arrow {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .chapter-nav__index {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    white-space: nowrap;
    transition: color var(--transition), border-color var(--transition);
  }

  .chapter-nav__index:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .chapter-nav__title { max-width: 120px; }
  }
</style>
