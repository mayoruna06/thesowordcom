---
import type { CollectionEntry } from 'astro:content';
import { collectTagStats, tagHref } from '../tags';

const base = import.meta.env.BASE_URL;

interface Props {
  works: CollectionEntry<'works'>[];
  chapterCountByWork: Record<string, number>;
  announcements: CollectionEntry<'announcements'>[];
}

const { works, chapterCountByWork, announcements } = Astro.props;

// 排行：章節數最多的前 5 部
const ranked = [...works]
  .sort((a, b) => (chapterCountByWork[b.slug] ?? 0) - (chapterCountByWork[a.slug] ?? 0))
  .slice(0, 5);

// 標籤雲：依公開作品數排序，並保留每個標籤的作品數。
const allTags = collectTagStats(works.map(w => w.data.tags));

const dateStr = (d: Date) =>
  d.toLocaleDateString('zh-TW', { month: '2-digit', day: '2-digit' });
---

<aside class="sidebar">

  {ranked.length > 0 && (
    <div class="sidebar-card">
      <div class="sidebar-card-title">作品排行</div>
      <div class="rank-list">
        {ranked.map((work, i) => (
          <a href={`${base}works/${work.slug}/`} class="rank-item">
            <span class:list={['rank-num', { top: i < 3 }]}>{i + 1}</span>
            <span class="rank-title">{work.data.title}</span>
            <span class="rank-count">{chapterCountByWork[work.slug] ?? 0} 章</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="sidebar-card">
    <div class="sidebar-card-title">最新公告</div>
    {announcements.length > 0
      ? (
        <div class="announce-list">
          {announcements.slice(0, 5).map(ann => (
            <a class="announce-item" href={`${base}announcements/${ann.slug}/`}>
              <span class="ann-date">{dateStr(ann.data.publishedAt)}</span>
              <span class="ann-title">{ann.data.title}</span>
            </a>
          ))}
          <a class="announce-more" href={`${base}announcements/`}>查看全部公告 →</a>
        </div>
      )
      : <p class="sidebar-empty">暫無公告</p>
    }
  </div>

  {allTags.length > 0 && (
    <div class="sidebar-card">
      <div class="sidebar-card-title">標籤分類</div>
      <div class="tag-cloud">
        {allTags.map(t => (
          <a class="tag" href={tagHref(base, t.key)} aria-label={t.label + '，' + t.count + ' 部作品'}>
            <span>{t.label}</span>
            <span class="tag-count">{t.count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

</aside>

<style>
  .rank-list { display: flex; flex-direction: column; }

  .rank-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--bg2);
    text-decoration: none;
    color: inherit;
    transition: color var(--transition);
  }
  .rank-item:last-child { border-bottom: none; }
  .rank-item:hover .rank-title { color: var(--accent); }

  .rank-num {
    font-family: var(--font-deco);
    font-size: 16px;
    color: var(--accent2);
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }
  .rank-num.top { color: var(--red); }

  .rank-title { font-size: 13px; color: var(--ink); flex: 1; line-height: 1.3; }
  .rank-count  { font-size: 11px; color: var(--ink3); white-space: nowrap; }

  .announce-list { display: flex; flex-direction: column; }

  .announce-item {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--bg2);
    color: inherit;
    text-decoration: none;
  }
  .announce-item:hover .ann-title { color: var(--accent); }
  .announce-item:last-child { border-bottom: none; }

  .ann-date  { font-size: 11px; color: var(--ink3); white-space: nowrap; letter-spacing: 0.06em; }
  .ann-title { font-size: 13px; color: var(--ink2); line-height: 1.4; }

  .announce-more { display: block; margin-top: 10px; color: var(--ink3); font-size: 12px; text-align: right; text-decoration: none; }
  .announce-more:hover { color: var(--accent); }

  .tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }
  .tag-count { margin-left: 4px; color: var(--ink3); font-size: 10px; }

  .sidebar-empty { font-size: 13px; color: var(--ink3); padding: 4px 0; }
</style>
