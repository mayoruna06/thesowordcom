---
import type { CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;

interface Props {
  work: CollectionEntry<'works'>;
  chapterCount?: number;
  isNew?: boolean;
}

const { work, chapterCount = 0, isNew = false } = Astro.props;
const { title, subtitle, author, authorSlug, cover, status, tags } = work.data;
const workHref = `${base}works/${work.slug}/`;
const authorHref = authorSlug ? `${base}authors/${authorSlug}/` : null;

const badgeClass = isNew ? 'badge-new' : status === 'ongoing' ? 'badge-ongoing' : status === 'hiatus' ? 'badge-hiatus' : 'badge-end';
const badgeLabel = isNew ? 'NEW' : status === 'ongoing' ? '連載中' : status === 'hiatus' ? '暫停' : '完結';
---

<div class="novel-card">
  <a class="cover-link" href={workHref} aria-label={title}>
    <div class="cover-wrap">
      {cover
        ? <img src={`${base}images/covers/${cover}`} alt={title} class="cover-img" loading="lazy" />
        : (
          <div class="cover-blank">
            <div class="cover-blank-deco">書</div>
            <div class="cover-blank-title">{title}</div>
            <div class="cover-blank-author">{author}</div>
          </div>
        )
      }
      <span class={`badge ${badgeClass}`}>{badgeLabel}</span>
    </div>
  </a>
  <div class="novel-info">
    <a class="novel-name" href={workHref}>{title}</a>
    {subtitle && <div class="novel-subtitle" title={subtitle}>{subtitle}</div>}
    <div class="novel-meta">
      {authorHref ? <a class="author-link" href={authorHref}>{author}</a> : <span>{author}</span>}
      {tags[0] && <><span>・</span><span>{tags[0]}</span></>}
    </div>
  </div>
</div>

<style>
  .novel-card {
    cursor: pointer;
    transition: transform 0.25s ease;
  }
  .novel-card:hover { transform: translateY(-4px); }

  .novel-card a { text-decoration: none; color: inherit; display: block; }
  .novel-meta .author-link { display: inline; }
  .novel-meta .author-link:hover { color: var(--accent); text-decoration: underline; }

  /* 書封 */
  .cover-wrap {
    position: relative;
    aspect-ratio: 2/3;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12), 2px 2px 0 rgba(0,0,0,0.06);
  }

  .cover-img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* 空白封面 */
  .cover-blank {
    width: 100%; height: 100%;
    background: var(--white);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    position: relative;
    border: 1px solid var(--line);
  }

  .cover-blank::before {
    content: '';
    position: absolute;
    top: 8px; left: 8px; right: 8px; bottom: 8px;
    border: 1px solid var(--line);
    border-radius: 2px;
    pointer-events: none;
  }

  .cover-blank-deco {
    position: absolute;
    top: 20px; right: 20px;
    font-family: var(--font-deco);
    font-size: 22px;
    color: var(--line);
    z-index: 1;
  }

  .cover-blank-title {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.15em;
    text-align: center;
    line-height: 1.6;
    z-index: 1;
  }

  .cover-blank-author {
    position: absolute;
    bottom: 20px;
    font-size: 11px;
    color: var(--ink3);
    letter-spacing: 0.2em;
    z-index: 1;
  }

  /* 資訊 */
  .novel-info { padding: 10px 2px 0; }

  .novel-name {
    font-family: var(--font-serif);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.4;
    letter-spacing: 0.05em;
  }

  .novel-subtitle {
    margin-top: 3px;
    color: var(--ink3);
    font-size: 12px;
    line-height: 1.5;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .novel-meta {
    margin-top: 4px;
    font-size: 12px;
    color: var(--ink3);
    display: flex;
    gap: 4px;
    align-items: center;
    flex-wrap: wrap;
  }
</style>
