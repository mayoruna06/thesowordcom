---
import type { CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;

interface Props {
  work: CollectionEntry<'works'>;
  chapterCount?: number;
}

const { work, chapterCount = 0 } = Astro.props;
const { title, summary, cover, status, tags, genre } = work.data;

const statusLabel: Record<string, string> = {
  ongoing: '連載中', completed: '已完結', hiatus: '暫停更新',
};

const genreLabel: Record<string, string> = {
  romance: '言情', fantasy: '奇幻', 'sci-fi': '科幻',
  thriller: '懸疑', 'slice-of-life': '日常', other: '其他',
};
---

<article class="work-card">
  <a href={`${base}works/${work.slug}/`} class="work-card__link" aria-label={title}>
    <div class="work-card__cover">
      {cover
        ? <img src={`${base}images/covers/${cover}`} alt="" loading="lazy" />
        : <div class="work-card__cover-placeholder">{title[0]}</div>
      }
    </div>
    <div class="work-card__body">
      <div class="work-card__header">
        <span class:list={['badge', `badge--${status}`]}>{statusLabel[status] ?? status}</span>
        <span class="work-card__genre">{genreLabel[genre] ?? genre}</span>
      </div>
      <h2 class="work-card__title">{title}</h2>
      <p class="work-card__summary">{summary}</p>
      <div class="work-card__footer">
        <span class="work-card__chapters">{chapterCount} 章</span>
        <div class="work-card__tags">
          {tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  .work-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .work-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .work-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .work-card__cover {
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--color-surface);
  }

  .work-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .work-card:hover .work-card__cover img { transform: scale(1.04); }

  .work-card__cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--color-text-muted);
  }

  .work-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .work-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .work-card__genre {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .work-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: 1.3;
  }

  .work-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .work-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .work-card__chapters {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .work-card__tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }
</style>
