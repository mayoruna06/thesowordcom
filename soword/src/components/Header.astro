---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const isHome  = currentPath === base;
const isWorks = currentPath.startsWith(`${base}works/`);
---

<header class="site-header">
  <a class="logo" href={base}>
    <div class="logo-dot"></div>
    小書樓
  </a>
  <nav>
    <a href={base} class:list={{ active: isHome }}>首頁</a>
    <a href={`${base}works/`} class:list={{ active: isWorks }}>作品</a>
  </nav>
  <div class="search-wrap" role="search">
    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input type="text" placeholder="搜尋小說、作者…" aria-label="搜尋" />
  </div>
</header>

<style>
  .site-header {
    background: var(--white);
    border-bottom: 1px solid var(--line);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-dot {
    width: 8px; height: 8px;
    background: var(--accent2);
    border-radius: 50%;
    flex-shrink: 0;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  nav a {
    font-size: 14px;
    color: var(--ink2);
    font-weight: 400;
    letter-spacing: 0.06em;
    transition: color var(--transition);
    text-decoration: none;
  }

  nav a:hover, nav a.active { color: var(--ink); }

  .search-wrap {
    display: flex;
    align-items: center;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 6px 14px;
    gap: 8px;
  }

  .search-wrap input {
    border: none;
    background: transparent;
    font-size: 13px;
    font-family: var(--font-sans);
    color: var(--ink);
    outline: none;
    width: 140px;
  }

  .search-wrap input::placeholder { color: var(--ink3); }
  .search-wrap svg { color: var(--ink3); flex-shrink: 0; }

  @media (max-width: 768px) {
    .site-header { padding: 0 16px; }
    nav { display: none; }
    .search-wrap { display: none; }
  }
</style>
