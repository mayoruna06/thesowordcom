---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const isHome  = currentPath === base;
const isAnnouncements = currentPath.startsWith(`${base}announcements/`);
---

<header class="site-header">
  <a class="logo" href={base}>
    <div class="logo-dot"></div>
    小書樓
  </a>
  <nav>
    <a href={base} class:list={{ active: isHome }}>首頁</a>
    <a href={`${base}announcements/`} class:list={{ active: isAnnouncements }}>公告</a>
    <a href={`${base}account/`}>登入</a>
  </nav>
  <form class="search-wrap" role="search" action={`${base}search/`} method="get">
    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input name="q" type="search" maxlength="50" placeholder="搜尋小說、內文…" aria-label="搜尋小說與內文" />
  </form>
</header>

<style>
  .site-header {
    background: var(--white);
    border-bottom: 1px solid var(--line);
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    justify-self: start;
  }

  .logo-dot {
    width: 8px; height: 8px;
    background: var(--accent2);
    border-radius: 50%;
    flex-shrink: 0;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  nav a {
    font-size: 14px;
    color: var(--ink2);
    font-weight: 400;
    letter-spacing: 0.06em;
    transition: color var(--transition);
    text-decoration: none;
  }

  nav a:hover, nav a.active { color: var(--ink); }

  .search-wrap {
    display: flex;
    align-items: center;
    justify-self: end;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 6px 14px;
    gap: 8px;
  }

  .search-wrap input {
    border: none;
    background: transparent;
    font-size: 13px;
    font-family: var(--font-sans);
    color: var(--ink);
    outline: none;
    width: 140px;
  }

  .search-wrap input::placeholder { color: var(--ink3); }
  .search-wrap svg { color: var(--ink3); flex-shrink: 0; }

  @media (max-width: 768px) {
    .site-header { padding: 0 16px; }
    nav { display: none; }
    .search-wrap { display: flex; width: min(180px, 52vw); padding-inline: 10px; }
    .search-wrap input { width: 100%; min-width: 0; }
  }
</style>
