---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span class="footer-copy">© {year} 勒索沃德 · 小書樓</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    padding: 24px 0;
    margin-top: 0;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-copy { font-size: 12px; color: var(--ink3); letter-spacing: 0.06em; }
</style>
