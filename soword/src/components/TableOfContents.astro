---
import type { CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;

interface Props {
  workSlug: string;
  chapters: CollectionEntry<'chapters'>[];
  currentSlug?: string;
}

const { workSlug, chapters, currentSlug } = Astro.props;
const sorted = [...chapters].sort((a, b) => a.data.chapter - b.data.chapter);

const isNew = (d: Date) => Date.now() - d.getTime() < 7 * 86400_000;
---

{sorted.length === 0
  ? <p class="toc-empty">尚無章節，敬請期待</p>
  : (
    <div class="chapter-grid">
      {sorted.map((ch, i) => (
        <a
          href={`${base}works/${workSlug}/${ch.slug}/`}
          class:list={['chapter-item', { 'current-ch': ch.slug === currentSlug }]}
        >
          <span class="ch-num">{i + 1}</span>
          <span class="ch-title">{ch.data.title}</span>
          {ch.data.wordCount && (
            <span class="ch-wc">{ch.data.wordCount.toLocaleString()}</span>
          )}
          {isNew(ch.data.updatedAt ?? ch.data.publishedAt) && (
            <span class="ch-new">NEW</span>
          )}
        </a>
      ))}
    </div>
  )
}

<style>
  .toc-empty {
    font-size: 14px;
    color: var(--ink3);
    padding: 32px 0;
    text-align: center;
    letter-spacing: 0.06em;
  }

  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 2px;
  }

  .chapter-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 3px;
    text-decoration: none;
    color: inherit;
    transition: background var(--transition);
  }
  .chapter-item:hover { background: var(--warm); text-decoration: none; }
  .chapter-item.current-ch { background: var(--bg2); }

  .ch-num {
    font-family: var(--font-deco);
    font-size: 13px;
    color: var(--ink3);
    width: 28px;
    text-align: right;
    flex-shrink: 0;
  }

  .ch-title {
    font-size: 13px;
    color: var(--ink2);
    letter-spacing: 0.04em;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chapter-item:hover .ch-title, .chapter-item.current-ch .ch-title {
    color: var(--ink);
  }

  .ch-wc {
    font-size: 11px;
    color: var(--ink3);
    letter-spacing: 0.04em;
    white-space: nowrap;
    margin-left: auto;
  }

  .ch-new {
    font-size: 9px;
    color: var(--red);
    border: 1px solid var(--red);
    padding: 1px 4px;
    border-radius: 2px;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }
</style>
