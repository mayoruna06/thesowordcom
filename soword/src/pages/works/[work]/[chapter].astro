---
import ChapterLayout from '@layouts/ChapterLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works', ({ data }) => data.status !== 'draft');
  const allChapters = await getCollection('chapters');

  const workSlugs = new Set(works.map(w => w.slug));

  return allChapters
    .filter(ch => workSlugs.has(ch.data.work))
    .map(ch => {
      const workChapters = allChapters
        .filter(c => c.data.work === ch.data.work)
        .sort((a, b) => a.data.chapter - b.data.chapter);

      const idx = workChapters.findIndex(c => c.slug === ch.slug);

      return {
        params: { work: ch.data.work, chapter: ch.slug },
        props: {
          work: works.find(w => w.slug === ch.data.work)!,
          chapter: ch,
          chapters: workChapters,
          prev: workChapters[idx - 1],
          next: workChapters[idx + 1],
        },
      };
    });
}

const { work, chapter, chapters, prev, next } = Astro.props;
// 內文以純文字原樣呈現：不解析 Markdown，換行與空行都依作者輸入保留
const plainBody = chapter.body.replace(/\r\n/g, '\n').replace(/^\n+|\s+$/g, '');
---

<ChapterLayout work={work} chapter={chapter} chapters={chapters} prev={prev} next={next}>
  <div class="plain-text">{plainBody}</div>
</ChapterLayout>

<style>
  .plain-text {
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
</style>
