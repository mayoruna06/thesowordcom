---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import WorkCard from '@components/WorkCard.astro';
import { avatarFace } from '../../avatars';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const [authors, works] = await Promise.all([
    getCollection('authors'),
    getCollection('works', ({ data }) => data.status !== 'draft'),
  ]);
  return authors.map(author => ({
    params: { author: author.slug },
    props: {
      author,
      works: works.filter(work => work.data.authorSlug === author.slug),
    },
  }));
}

const { author, works } = Astro.props;
const { Content } = await author.render();
const face = avatarFace(author.data.avatar, author.data.displayName);
---

<BaseLayout
  title={author.data.displayName}
  description={author.data.bio || `${author.data.displayName} 的作者頁`}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <main class="author-page container">
    <a class="back" href={import.meta.env.BASE_URL}>← 回到小書樓</a>
    <header class="profile">
      <div class="avatar" aria-hidden="true" style={`background:${face.tone}`}>{face.text}</div>
      <div>
        <h1>{author.data.displayName}</h1>
        {author.data.bio && <p>{author.data.bio}</p>}
        <Content />
      </div>
    </header>

    {author.data.message && (
      <section class="author-message" aria-labelledby="author-message-title">
        <h2 id="author-message-title">作者想說的話</h2>
        <p>{author.data.message}</p>
      </section>
    )}

    <section>
      <h2>作品</h2>
      {works.length ? (
        <div class="works-grid">
          {works.map(work => <WorkCard work={work} />)}
        </div>
      ) : <p class="empty">目前沒有公開作品。</p>}
    </section>
  </main>
</BaseLayout>

<style>
  .author-page { padding: 40px 16px 80px; }
  .back { color: var(--ink3); font-size: 13px; text-decoration: none; }
  .back:hover { color: var(--accent); text-decoration: underline; }
  .profile { display: flex; gap: 20px; align-items: center; margin: 28px 0 44px; }
  .avatar { width: 72px; height: 72px; border-radius: 50%; border: 1px solid var(--line);
    display: grid; place-items: center; font-family: var(--font-serif); font-size: 28px; color: var(--ink2); }
  h1 { margin: 0 0 8px; font-family: var(--font-serif); font-size: 30px; letter-spacing: .08em; }
  h2 { font-family: var(--font-serif); font-size: 20px; margin-bottom: 20px; }
  .profile p, .empty { color: var(--ink2); line-height: 1.8; margin: 0; }
  .author-message { margin: -16px 0 44px; padding: 22px 24px; border: 1px solid var(--line);
    border-radius: 10px; background: var(--white); }
  .author-message h2 { margin: 0 0 12px; }
  .author-message p { margin: 0; color: var(--ink2); line-height: 1.9; white-space: pre-wrap; }
  .works-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 28px 20px; }
</style>
