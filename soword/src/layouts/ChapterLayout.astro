---
import BaseLayout from './BaseLayout.astro';
import Footer from '@components/Footer.astro';
import '../styles/typography.css';
import type { CollectionEntry } from 'astro:content';
import { ADMIN_URL } from '../site.config';

const base = import.meta.env.BASE_URL;

interface Props {
  work: CollectionEntry<'works'>;
  chapter: CollectionEntry<'chapters'>;
  chapters: CollectionEntry<'chapters'>[];
  prev?: CollectionEntry<'chapters'>;
  next?: CollectionEntry<'chapters'>;
}

const { work, chapter, chapters, prev, next } = Astro.props;
const { title, publishedAt, updatedAt } = chapter.data;

const sorted = [...chapters].sort((a, b) => a.data.chapter - b.data.chapter);
const pos = sorted.findIndex(c => c.slug === chapter.slug) + 1;
---

<BaseLayout
  title={`${title} — ${work.data.title}`}
  description={`《${work.data.title}》${title}`}
>
  <Footer slot="footer" />

  <!-- Reading Bar -->
  <div class="reading-bar">
    <div class="reading-bar-nav">
      <a class="back-btn" href={`${base}works/${work.slug}/`}>← 返回</a>
      <span class="sep">|</span>
      <div class="breadcrumb">
        <span>{work.data.title}</span>
        <span>›</span>
        <span class="bc-current">{title}</span>
      </div>
    </div>
    <div class="reading-controls">
      <button class="ctrl-btn" id="bookmark-chapter" title="收藏並記住目前章節">🔖 書籤本章</button>
      <button class="ctrl-btn" id="font-sm" title="縮小字體">A−</button>
      <button class="ctrl-btn" id="font-lg" title="放大字體">A+</button>
    </div>
  </div>

  <!-- Reading Content -->
  <div class="reading-content">
    <div class="chapter-heading">
      <small>《{work.data.title}》</small>
      {title}
    </div>

    <div class="chapter-body">
      <slot />
    </div>

    <section class="comments" aria-labelledby="comments-title">
      <div class="comments-heading">
        <h2 id="comments-title">讀者留言</h2>
        <span id="comment-count"></span>
      </div>
      <div id="comment-list" class="comment-list"><p class="comment-empty">載入留言中…</p></div>
      <form id="comment-form" class="comment-form">
        <label for="comment-body">留下想法</label>
        <textarea id="comment-body" maxlength="1000" rows="4" placeholder="請友善交流，留言送出後會先由站方審核。" required></textarea>
        <div class="comment-form-foot">
          <span id="comment-status">需登入會員才能留言</span>
          <button type="submit">送出留言</button>
        </div>
      </form>
    </section>
    <!-- Chapter Nav -->
    <div class="chapter-nav-bar">
      {prev
        ? <a class="ch-nav-btn" href={`${base}works/${work.slug}/${prev.slug}/`}>← 上一章</a>
        : <button class="ch-nav-btn" disabled>← 上一章</button>
      }
      <span class="chapter-pos">{pos} / {chapters.length}</span>
      {next
        ? <a class="ch-nav-btn" href={`${base}works/${work.slug}/${next.slug}/`}>下一章 →</a>
        : <button class="ch-nav-btn" disabled>下一章 →</button>
      }
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Reading Bar ── */
  .reading-bar {
    background: var(--white);
    border-bottom: 1px solid var(--line);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .reading-bar-nav {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    overflow: hidden;
  }

  .back-btn {
    font-size: 13px;
    color: var(--ink3);
    letter-spacing: 0.06em;
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition);
    flex-shrink: 0;
  }
  .back-btn:hover { color: var(--ink); text-decoration: none; }

  .sep { color: var(--line); flex-shrink: 0; }

  .breadcrumb {
    font-size: 13px;
    color: var(--ink3);
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 6px;
    overflow: hidden;
  }
  .bc-current {
    color: var(--ink2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reading-controls { display: flex; gap: 8px; align-items: center; flex-shrink: 0; }

  .ctrl-btn {
    font-size: 12px;
    color: var(--ink3);
    cursor: pointer;
    padding: 5px 10px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: transparent;
    letter-spacing: 0.06em;
    transition: border-color var(--transition), color var(--transition);
  }
  .ctrl-btn:hover { border-color: var(--accent); color: var(--ink); }
  .ctrl-btn.is-bookmarked { border-color: var(--accent); color: var(--accent); }

  /* ── Comments ── */
  .comments { margin-top: 64px; padding-top: 36px; border-top: 1px solid var(--line); }
  .comments-heading { display: flex; align-items: baseline; gap: 10px; margin-bottom: 20px; }
  .comments h2 { margin: 0; font-family: var(--font-serif); font-size: 20px; font-weight: 500; }
  #comment-count, #comment-status { color: var(--ink3); font-size: 12px; }
  .comment-list { display: grid; gap: 12px; }
  .comment-item { padding: 16px 18px; border: 1px solid var(--line); border-radius: 6px; background: var(--white); }
  .comment-meta { display: flex; justify-content: space-between; gap: 12px; margin-bottom: 8px; color: var(--ink3); font-size: 12px; }
  .comment-author { color: var(--ink2); font-weight: 600; }
  .comment-text { margin: 0; white-space: pre-wrap; overflow-wrap: anywhere; color: var(--ink2); font-size: 14px; line-height: 1.8; }
  .comment-empty { color: var(--ink3); font-size: 13px; }
  .comment-form { display: grid; gap: 10px; margin-top: 24px; padding: 18px; border-radius: 6px; background: var(--warm); }
  .comment-form label { color: var(--ink2); font-size: 13px; font-weight: 600; }
  .comment-form textarea { box-sizing: border-box; width: 100%; resize: vertical; padding: 12px; border: 1px solid var(--line); border-radius: 4px; background: var(--white); color: var(--ink); font: 14px/1.7 var(--font-sans); }
  .comment-form textarea:focus { outline: 1px solid var(--accent); border-color: var(--accent); }
  .comment-form-foot { display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .comment-form button { padding: 8px 16px; border: 1px solid var(--accent); border-radius: 4px; background: var(--accent); color: white; cursor: pointer; }
  .comment-form button:disabled { opacity: .55; cursor: wait; }
  /* ── Chapter Nav ── */
  .chapter-nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 60px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }

  .ch-nav-btn {
    font-size: 13px;
    color: var(--ink2);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--white);
    letter-spacing: 0.08em;
    transition: border-color var(--transition), background var(--transition);
    text-decoration: none;
    font-family: var(--font-sans);
  }
  .ch-nav-btn:hover { border-color: var(--accent); background: var(--warm); text-decoration: none; color: var(--ink); }
  .ch-nav-btn:disabled { opacity: 0.4; cursor: default; pointer-events: none; }

  .chapter-pos { font-size: 12px; color: var(--ink3); letter-spacing: 0.06em; }

  @media (max-width: 768px) {
    .reading-bar { padding: 0 16px; }
    .breadcrumb { display: none; }
    .sep { display: none; }
    .reading-controls { gap: 4px; }
    #bookmark-chapter { padding-inline: 8px; }
  }
  @media (max-width: 480px) {
    #bookmark-chapter { font-size: 0; width: 34px; padding-inline: 5px; }
    #bookmark-chapter::before { content: '🔖'; font-size: 13px; }
  }
</style>

<script define:vars={{ workSlug: work.slug, chapterSlug: chapter.slug, adminUrl: ADMIN_URL, baseUrl: base }}>
  // 記憶閱讀進度
  localStorage.setItem(`last-chapter-${workSlug}`, chapterSlug);

  // 登入讀者：同步進度到雲端（未登入時安靜失敗即可）
  fetch(`${adminUrl}/api/reader/progress`, {
    method: 'POST', credentials: 'include',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ work_slug: workSlug, chapter_slug: chapterSlug }),
  }).catch(() => {});

  // 收藏本章：顯示既有狀態；登入後可把書籤更新到目前章節
  const bookmarkChapter = document.getElementById('bookmark-chapter');
  const renderChapterBookmark = (savedChapter) => {
    if (!bookmarkChapter) return;
    const isCurrent = savedChapter === chapterSlug;
    bookmarkChapter.textContent = isCurrent ? '✓ 已收藏本章' : '🔖 更新書籤到本章';
    bookmarkChapter.classList.toggle('is-bookmarked', Boolean(savedChapter));
  };

  fetch(`${adminUrl}/api/reader/bookmarks`, { credentials: 'include' })
    .then(r => r.ok ? r.json() : [])
    .then(rows => {
      const hit = rows.find(b => b.work_slug === workSlug);
      if (hit) renderChapterBookmark(hit.chapter_slug || 'saved');
    })
    .catch(() => {});

  bookmarkChapter?.addEventListener('click', async () => {
    bookmarkChapter.setAttribute('disabled', '');
    const r = await fetch(`${adminUrl}/api/reader/bookmarks`, {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ work_slug: workSlug, chapter_slug: chapterSlug }),
    }).catch(() => null);
    if (r?.status === 401) {
      const next = encodeURIComponent(location.pathname + location.search + location.hash);
      location.href = `${baseUrl}account/?next=${next}`;
      return;
    }
    if (r?.ok) renderChapterBookmark(chapterSlug);
    else bookmarkChapter.textContent = '稍後再試';
    bookmarkChapter.removeAttribute('disabled');
  });
  // 留言：公開讀取核准內容；會員送出後先進入待審
  const commentList = document.getElementById('comment-list');
  const commentCount = document.getElementById('comment-count');
  const commentForm = document.getElementById('comment-form');
  const commentBody = document.getElementById('comment-body');
  const commentStatus = document.getElementById('comment-status');
  const commentSubmit = commentForm?.querySelector('button');
  const commentParams = new URLSearchParams({ work_slug: workSlug, chapter_slug: chapterSlug });

  const renderComments = (rows) => {
    if (!commentList) return;
    commentList.replaceChildren();
    if (!rows.length) {
      const empty = document.createElement('p');
      empty.className = 'comment-empty'; empty.textContent = '目前還沒有公開留言。';
      commentList.append(empty);
    } else rows.forEach(row => {
      const item = document.createElement('article'); item.className = 'comment-item';
      const meta = document.createElement('div'); meta.className = 'comment-meta';
      const author = document.createElement('span'); author.className = 'comment-author';
      author.textContent = row.display_name || '讀者';
      const time = document.createElement('time'); time.dateTime = row.created_at;
      time.textContent = new Date(row.created_at).toLocaleString('zh-TW');
      const body = document.createElement('p'); body.className = 'comment-text'; body.textContent = row.body;
      meta.append(author, time); item.append(meta, body); commentList.append(item);
    });
    if (commentCount) commentCount.textContent = `${rows.length} 則`;
  };

  const loadComments = () => fetch(`${adminUrl}/api/reader/comments?${commentParams}`)
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(renderComments)
    .catch(() => { if (commentList) commentList.textContent = '留言暫時無法載入。'; });
  loadComments();

  fetch(`${adminUrl}/api/reader/me`, { credentials: 'include' })
    .then(r => { if (r.ok && commentStatus) commentStatus.textContent = '留言送出後會先由站方審核'; })
    .catch(() => {});

  commentForm?.addEventListener('submit', async event => {
    event.preventDefault();
    const body = commentBody?.value.trim() || '';
    if (!body) return;
    commentSubmit?.setAttribute('disabled', '');
    if (commentStatus) commentStatus.textContent = '送出中…';
    const r = await fetch(`${adminUrl}/api/reader/comments`, {
      method: 'POST', credentials: 'include', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ work_slug: workSlug, chapter_slug: chapterSlug, body }),
    }).catch(() => null);
    if (r?.status === 401) {
      const next = encodeURIComponent(location.pathname + location.search + '#comments-title');
      location.href = `${baseUrl}account/?next=${next}`; return;
    }
    const data = await r?.json().catch(() => ({}));
    if (commentStatus) commentStatus.textContent = r?.ok
      ? (data.message || '留言已送審') : (data.error || '留言送出失敗，請稍後再試');
    if (r?.ok && commentBody) commentBody.value = '';
    commentSubmit?.removeAttribute('disabled');
  });
  // 字體大小控制
  let size = 0;
  document.getElementById('font-sm')?.addEventListener('click', () => {
    size = Math.max(size - 1, -1);
    document.body.className = document.body.className
      .replace(/font-size-\w+/g, '').trim();
    if (size !== 0) document.body.classList.add(size < 0 ? 'font-size-sm' : 'font-size-lg');
  });
  document.getElementById('font-lg')?.addEventListener('click', () => {
    size = Math.min(size + 1, 1);
    document.body.className = document.body.className
      .replace(/font-size-\w+/g, '').trim();
    if (size !== 0) document.body.classList.add(size < 0 ? 'font-size-sm' : 'font-size-lg');
  });
</script>
