---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  work: CollectionEntry<'works'>;
}

const { work } = Astro.props;
const { title, summary, cover, genre, status, tags, contentWarning } = work.data;

const statusLabel: Record<string, string> = {
  ongoing: '連載中', completed: '已完結', hiatus: '暫停更新', draft: '草稿',
};

const genreLabel: Record<string, string> = {
  romance: '言情', fantasy: '奇幻', 'sci-fi': '科幻',
  thriller: '懸疑', 'slice-of-life': '日常', other: '其他',
};
---

<BaseLayout
  title={title}
  description={summary}
  ogImage={cover ? `/images/og/${work.slug}.jpg` : undefined}
>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="container" style="padding-top: var(--space-6);">
    <Breadcrumb items={[{ label: '作品', href: `${import.meta.env.BASE_URL}works/` }, { label: title }]} />
  </div>

  <div class="work-page">
    <div class="container work-page__inner">
      <aside class="work-page__cover">
        {cover
          ? <img src={`/images/covers/${cover}`} alt={`${title} 封面`} class="cover-img" />
          : <div class="cover-placeholder">{title[0]}</div>
        }
        <span class:list={['badge', `badge--${status}`]}>{statusLabel[status]}</span>
      </aside>

      <div class="work-page__info">
        <h1 class="work-page__title">{title}</h1>
        <div class="work-page__meta">
          <span>{genreLabel[genre]}</span>
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
        {contentWarning.length > 0 && (
          <p class="content-warning">⚠️ 內容警示：{contentWarning.join('、')}</p>
        )}
        <p class="work-page__summary">{summary}</p>
      </div>
    </div>

    <div class="container" style="padding-top: var(--space-8);">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .work-page { padding-bottom: var(--space-16); }

  .work-page__inner {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
    padding-top: var(--space-8);
  }

  .cover-img {
    width: 200px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .cover-placeholder {
    width: 200px;
    height: 280px;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .work-page__cover { display: flex; flex-direction: column; gap: var(--space-3); align-items: flex-start; }

  .work-page__title { font-size: var(--text-3xl); font-weight: 700; margin-bottom: var(--space-3); }

  .work-page__meta {
    display: flex; flex-wrap: wrap; gap: var(--space-2);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm); color: var(--color-text-muted);
    align-items: center;
  }

  .content-warning {
    font-size: var(--text-sm);
    color: #c0392b;
    background: #fdf2f2;
    border: 1px solid #f5c6cb;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-4);
  }

  .work-page__summary {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .work-page__inner { grid-template-columns: 1fr; }
    .cover-img, .cover-placeholder { width: 140px; height: 196px; }
  }
</style>
